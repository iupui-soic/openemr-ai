{
  "library": {
    "identifier": {
      "id": "Lung_Cancer_Screening_CDS",
      "version": "1"
    },
    "schemaIdentifier": {
      "id": "urn:hl7-org:elm",
      "version": "r1"
    },
    "usings": {
      "def": [ {
        "localIdentifier": "System",
        "uri": "urn:hl7-org:elm-types:r1"
      }, {
        "localIdentifier": "FHIR",
        "uri": "http://hl7.org/fhir",
        "version": "4.0.1"
      } ]
    },
    "valueSets": {
      "def": [ {
        "name": "Tobacco User",
        "id": "2.16.840.1.113883.3.526.3.1170",
        "accessLevel": "Public"
      }, {
        "name": "Low Dose CT Chest",
        "id": "2.16.840.1.113762.1.4.1047.97",
        "accessLevel": "Public"
      } ]
    },
    "statements": {
      "def": [ {
        "name": "Patient",
        "context": "Patient",
        "expression": {
          "type": "SingletonFrom",
          "operand": {
            "dataType": "{http://hl7.org/fhir}Patient",
            "templateId": "http://hl7.org/fhir/StructureDefinition/Patient",
            "type": "Retrieve"
          }
        }
      }, {
        "name": "In Demographic",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "And",
          "operand": [ {
            "type": "GreaterOrEqual",
            "operand": [ {
              "precision": "Year",
              "type": "CalculateAge",
              "operand": {
                "path": "birthDate",
                "type": "Property",
                "source": { "name": "Patient", "type": "ExpressionRef" }
              }
            }, {
              "valueType": "{urn:hl7-org:elm-types:r1}Integer",
              "value": "50",
              "type": "Literal"
            } ]
          }, {
            "type": "LessOrEqual",
            "operand": [ {
              "precision": "Year",
              "type": "CalculateAge",
              "operand": {
                "path": "birthDate",
                "type": "Property",
                "source": { "name": "Patient", "type": "ExpressionRef" }
              }
            }, {
              "valueType": "{urn:hl7-org:elm-types:r1}Integer",
              "value": "80",
              "type": "Literal"
            } ]
          } ]
        }
      }, {
        "name": "Has Smoking History",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "Exists",
          "operand": {
            "type": "Query",
            "source": [ {
              "alias": "C",
              "expression": {
                "dataType": "{http://hl7.org/fhir}Condition",
                "templateId": "http://hl7.org/fhir/StructureDefinition/Condition",
                "codeProperty": "code",
                "type": "Retrieve",
                "codes": { "name": "Tobacco User", "type": "ValueSetRef" }
              }
            } ],
            "relationship": [],
            "where": {
              "type": "Equal",
              "operand": [ {
                "path": "clinicalStatus.coding[0].code",
                "scope": "C",
                "type": "Property"
              }, {
                "valueType": "{urn:hl7-org:elm-types:r1}String",
                "value": "active",
                "type": "Literal"
              } ]
            }
          }
        }
      }, {
        "name": "Has Recent LDCT",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "Exists",
          "operand": {
            "type": "Query",
            "source": [ {
              "alias": "S",
              "expression": {
                "dataType": "{http://hl7.org/fhir}Observation",
                "templateId": "http://hl7.org/fhir/StructureDefinition/Observation",
                "codeProperty": "code",
                "type": "Retrieve",
                "codes": { "name": "Low Dose CT Chest", "type": "ValueSetRef" }
              }
            } ],
            "relationship": [],
            "where": {
              "type": "In",
              "operand": [ {
                "path": "issued",
                "scope": "S",
                "type": "Property"
              }, {
                "lowClosed": true,
                "highClosed": true,
                "type": "Interval",
                "low": {
                  "type": "Subtract",
                  "operand": [ {
                    "type": "Today"
                  }, {
                    "value": 1,
                    "unit": "years",
                    "type": "Quantity"
                  } ]
                },
                "high": { "type": "Today" }
              } ]
            }
          }
        }
      }, {
        "name": "Needs Lung Cancer Screening",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "And",
          "operand": [ {
            "type": "And",
            "operand": [ {
              "name": "In Demographic",
              "type": "ExpressionRef"
            }, {
              "name": "Has Smoking History",
              "type": "ExpressionRef"
            } ]
          }, {
            "type": "Not",
            "operand": {
              "name": "Has Recent LDCT",
              "type": "ExpressionRef"
            }
          } ]
        }
      }, {
        "name": "InPopulation",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "name": "Needs Lung Cancer Screening",
          "type": "ExpressionRef"
        }
      }, {
        "name": "Recommendation",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "If",
          "condition": { "name": "InPopulation", "type": "ExpressionRef" },
          "then": {
            "valueType": "{urn:hl7-org:elm-types:r1}String",
            "value": "Perform annual low-dose CT (LDCT) scan for lung cancer screening",
            "type": "Literal"
          },
          "else": { "type": "Null" }
        }
      }, {
        "name": "Rationale",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "If",
          "condition": { "name": "InPopulation", "type": "ExpressionRef" },
          "then": {
            "valueType": "{urn:hl7-org:elm-types:r1}String",
            "value": "USPSTF recommends annual LDCT for lung cancer screening in adults aged 50-80 years with 20 pack-year smoking history.",
            "type": "Literal"
          },
          "else": { "type": "Null" }
        }
      }, {
        "name": "Indicator",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "If",
          "condition": { "name": "InPopulation", "type": "ExpressionRef" },
          "then": {
            "valueType": "{urn:hl7-org:elm-types:r1}String",
            "value": "warning",
            "type": "Literal"
          },
          "else": { "type": "Null" }
        }
      } ]
    }
  }
}