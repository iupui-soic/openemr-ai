{
  "library": {
    "identifier": {
      "id": "Alcohol_Misuse_Screening_CDS",
      "version": "1"
    },
    "schemaIdentifier": {
      "id": "urn:hl7-org:elm",
      "version": "r1"
    },
    "usings": {
      "def": [
        {
          "localIdentifier": "System",
          "uri": "urn:hl7-org:elm-types:r1"
        },
        {
          "localIdentifier": "FHIR",
          "uri": "http://hl7.org/fhir",
          "version": "4.0.1"
        }
      ]
    },
    "valueSets": {
      "def": [
        {
          "name": "Alcohol Use Screening",
          "id": "2.16.840.1.113883.3.526.3.1278",
          "accessLevel": "Public"
        }
      ]
    },
    "statements": {
      "def": [
        {
          "name": "Patient",
          "context": "Patient",
          "expression": {
            "type": "SingletonFrom",
            "operand": {
              "dataType": "{http://hl7.org/fhir}Patient",
              "templateId": "http://hl7.org/fhir/StructureDefinition/Patient",
              "type": "Retrieve"
            }
          }
        },
        {
          "name": "In Demographic",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "GreaterOrEqual",
            "operand": [
              {
                "precision": "Year",
                "type": "CalculateAge",
                "operand": {
                  "path": "birthDate",
                  "type": "Property",
                  "source": {
                    "name": "Patient",
                    "type": "ExpressionRef"
                  }
                }
              },
              {
                "valueType": "{urn:hl7-org:elm-types:r1}Integer",
                "value": "18",
                "type": "Literal"
              }
            ]
          }
        },
        {
          "name": "Has Recent Alcohol Screening",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Exists",
            "operand": {
              "type": "Query",
              "source": [
                {
                  "alias": "S",
                  "expression": {
                    "dataType": "{http://hl7.org/fhir}Observation",
                    "templateId": "http://hl7.org/fhir/StructureDefinition/Observation",
                    "codeProperty": "code",
                    "type": "Retrieve",
                    "codes": {
                      "name": "Alcohol Use Screening",
                      "type": "ValueSetRef"
                    }
                  }
                }
              ],
              "relationship": [],
              "where": {
                "type": "And",
                "operand": [
                  {
                    "type": "In",
                    "operand": [
                      {
                        "path": "issued",
                        "scope": "S",
                        "type": "Property"
                      },
                      {
                        "lowClosed": true,
                        "highClosed": true,
                        "type": "Interval",
                        "low": {
                          "type": "Subtract",
                          "operand": [
                            {
                              "type": "Today"
                            },
                            {
                              "value": 1,
                              "unit": "years",
                              "type": "Quantity"
                            }
                          ]
                        },
                        "high": {
                          "type": "Today"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Not",
                    "operand": {
                      "type": "IsNull",
                      "operand": {
                        "path": "value",
                        "scope": "S",
                        "type": "Property"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "name": "Needs Alcohol Misuse Screening",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "And",
            "operand": [
              {
                "name": "In Demographic",
                "type": "ExpressionRef"
              },
              {
                "type": "Not",
                "operand": {
                  "name": "Has Recent Alcohol Screening",
                  "type": "ExpressionRef"
                }
              }
            ]
          }
        },
        {
          "name": "InPopulation",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "name": "Needs Alcohol Misuse Screening",
            "type": "ExpressionRef"
          }
        },
        {
          "name": "Recommendation",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "InPopulation",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "Perform alcohol misuse screening using a validated tool (e.g., AUDIT-C)",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        },
        {
          "name": "Rationale",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "InPopulation",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "USPSTF recommends screening for unhealthy alcohol use in primary care settings in adults 18 years or older.",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        },
        {
          "name": "Indicator",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "InPopulation",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "warning",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        }
      ]
    }
  }
}