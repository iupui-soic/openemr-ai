{
  "library": {
    "identifier": {
      "id": "Osteoporosis_Screening_CDS",
      "version": "1"
    },
    "schemaIdentifier": {
      "id": "urn:hl7-org:elm",
      "version": "r1"
    },
    "usings": {
      "def": [ {
        "localIdentifier": "System",
        "uri": "urn:hl7-org:elm-types:r1"
      }, {
        "localIdentifier": "FHIR",
        "uri": "http://hl7.org/fhir",
        "version": "4.0.1"
      } ]
    },
    "valueSets": {
      "def": [ {
        "name": "Female Administrative Sex",
        "id": "2.16.840.1.113883.3.560.100.2",
        "accessLevel": "Public"
      }, {
        "name": "Osteoporosis",
        "id": "2.16.840.1.113883.3.464.1003.113.12.1038",
        "accessLevel": "Public"
      }, {
        "name": "Osteopenia",
        "id": "2.16.840.1.113883.3.464.1003.113.12.1049",
        "accessLevel": "Public"
      }, {
        "name": "Osteoporotic Fractures",
        "id": "2.16.840.1.113883.3.464.1003.113.12.1050",
        "accessLevel": "Public"
      }, {
        "name": "DEXA Dual Energy Xray Absorptiometry Bone Density",
        "id": "2.16.840.1.113762.1.4.1151.38",
        "accessLevel": "Public"
      } ]
    },
    "statements": {
      "def": [ {
        "name": "Patient",
        "context": "Patient",
        "expression": {
          "type": "SingletonFrom",
          "operand": {
            "dataType": "{http://hl7.org/fhir}Patient",
            "templateId": "http://hl7.org/fhir/StructureDefinition/Patient",
            "type": "Retrieve"
          }
        }
      }, {
        "name": "In Demographic",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "GreaterOrEqual",
          "operand": [ {
            "precision": "Year",
            "type": "CalculateAge",
            "operand": {
              "path": "birthDate",
              "type": "Property",
              "source": { "name": "Patient", "type": "ExpressionRef" }
            }
          }, {
            "valueType": "{urn:hl7-org:elm-types:r1}Integer",
            "value": "65",
            "type": "Literal"
          } ]
        }
      }, {
        "name": "Is Female",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "Equal",
          "operand": [ {
            "path": "gender.value",
            "type": "Property",
            "source": { "name": "Patient", "type": "ExpressionRef" }
          }, {
            "valueType": "{urn:hl7-org:elm-types:r1}String",
            "value": "female",
            "type": "Literal"
          } ]
        }
      }, {
        "name": "Has Osteoporosis Diagnosis",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "Exists",
          "operand": {
            "type": "Query",
            "source": [ {
              "alias": "C",
              "expression": {
                "dataType": "{http://hl7.org/fhir}Condition",
                "templateId": "http://hl7.org/fhir/StructureDefinition/Condition",
                "codeProperty": "code",
                "type": "Retrieve",
                "codes": { "name": "Osteoporosis", "type": "ValueSetRef" }
              }
            } ],
            "relationship": [],
            "where": {
              "type": "Equal",
              "operand": [ {
                "path": "clinicalStatus.coding[0].code",
                "scope": "C",
                "type": "Property"
              }, {
                "valueType": "{urn:hl7-org:elm-types:r1}String",
                "value": "active",
                "type": "Literal"
              } ]
            }
          }
        }
      }, {
        "name": "Has Osteopenia Diagnosis",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "Exists",
          "operand": {
            "type": "Query",
            "source": [ {
              "alias": "C",
              "expression": {
                "dataType": "{http://hl7.org/fhir}Condition",
                "templateId": "http://hl7.org/fhir/StructureDefinition/Condition",
                "codeProperty": "code",
                "type": "Retrieve",
                "codes": { "name": "Osteopenia", "type": "ValueSetRef" }
              }
            } ],
            "relationship": [],
            "where": {
              "type": "Equal",
              "operand": [ {
                "path": "clinicalStatus.coding[0].code",
                "scope": "C",
                "type": "Property"
              }, {
                "valueType": "{urn:hl7-org:elm-types:r1}String",
                "value": "active",
                "type": "Literal"
              } ]
            }
          }
        }
      }, {
        "name": "Has Osteoporotic Fracture",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "Exists",
          "operand": {
            "type": "Query",
            "source": [ {
              "alias": "C",
              "expression": {
                "dataType": "{http://hl7.org/fhir}Condition",
                "templateId": "http://hl7.org/fhir/StructureDefinition/Condition",
                "codeProperty": "code",
                "type": "Retrieve",
                "codes": { "name": "Osteoporotic Fractures", "type": "ValueSetRef" }
              }
            } ],
            "relationship": [],
            "where": {
              "type": "Not",
              "operand": {
                "type": "IsNull",
                "operand": {
                  "path": "clinicalStatus",
                  "scope": "C",
                  "type": "Property"
                }
              }
            }
          }
        }
      }, {
        "name": "Has Recent DEXA Scan",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "Exists",
          "operand": {
            "type": "Query",
            "source": [ {
              "alias": "S",
              "expression": {
                "dataType": "{http://hl7.org/fhir}Observation",
                "templateId": "http://hl7.org/fhir/StructureDefinition/Observation",
                "codeProperty": "code",
                "type": "Retrieve",
                "codes": { "name": "DEXA Dual Energy Xray Absorptiometry Bone Density", "type": "ValueSetRef" }
              }
            } ],
            "relationship": [],
            "where": {
              "type": "In",
              "operand": [ {
                "path": "issued",
                "scope": "S",
                "type": "Property"
              }, {
                "lowClosed": true,
                "highClosed": true,
                "type": "Interval",
                "low": {
                  "type": "Subtract",
                  "operand": [ {
                    "type": "Today"
                  }, {
                    "value": 2,
                    "unit": "years",
                    "type": "Quantity"
                  } ]
                },
                "high": { "type": "Today" }
              } ]
            }
          }
        }
      }, {
        "name": "Needs Osteoporosis Screening",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "And",
          "operand": [ {
            "type": "And",
            "operand": [ {
              "type": "And",
              "operand": [ {
                "type": "And",
                "operand": [ {
                  "type": "And",
                  "operand": [ {
                    "name": "In Demographic",
                    "type": "ExpressionRef"
                  }, {
                    "name": "Is Female",
                    "type": "ExpressionRef"
                  } ]
                }, {
                  "type": "Not",
                  "operand": {
                    "name": "Has Osteoporosis Diagnosis",
                    "type": "ExpressionRef"
                  }
                } ]
              }, {
                "type": "Not",
                "operand": {
                  "name": "Has Osteopenia Diagnosis",
                  "type": "ExpressionRef"
                }
              } ]
            }, {
              "type": "Not",
              "operand": {
                "name": "Has Osteoporotic Fracture",
                "type": "ExpressionRef"
              }
            } ]
          }, {
            "type": "Not",
            "operand": {
              "name": "Has Recent DEXA Scan",
              "type": "ExpressionRef"
            }
          } ]
        }
      }, {
        "name": "InPopulation",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "name": "Needs Osteoporosis Screening",
          "type": "ExpressionRef"
        }
      }, {
        "name": "Recommendation",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "If",
          "condition": { "name": "InPopulation", "type": "ExpressionRef" },
          "then": {
            "valueType": "{urn:hl7-org:elm-types:r1}String",
            "value": "Order DEXA bone density scan for osteoporosis screening",
            "type": "Literal"
          },
          "else": { "type": "Null" }
        }
      }, {
        "name": "Rationale",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "If",
          "condition": { "name": "InPopulation", "type": "ExpressionRef" },
          "then": {
            "valueType": "{urn:hl7-org:elm-types:r1}String",
            "value": "USPSTF recommends screening for osteoporosis with bone measurement testing (DXA) to prevent osteoporotic fractures in women 65 years or older.",
            "type": "Literal"
          },
          "else": { "type": "Null" }
        }
      }, {
        "name": "Indicator",
        "context": "Patient",
        "accessLevel": "Public",
        "expression": {
          "type": "If",
          "condition": { "name": "InPopulation", "type": "ExpressionRef" },
          "then": {
            "valueType": "{urn:hl7-org:elm-types:r1}String",
            "value": "warning",
            "type": "Literal"
          },
          "else": { "type": "Null" }
        }
      } ]
    }
  }
}