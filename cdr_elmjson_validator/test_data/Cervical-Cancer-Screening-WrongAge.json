{
  "library": {
    "identifier": {
      "id": "Cervical_Cancer_Screening_CDS",
      "version": "1"
    },
    "schemaIdentifier": {
      "id": "urn:hl7-org:elm",
      "version": "r1"
    },
    "usings": {
      "def": [
        {
          "localIdentifier": "System",
          "uri": "urn:hl7-org:elm-types:r1"
        },
        {
          "localIdentifier": "FHIR",
          "uri": "http://hl7.org/fhir",
          "version": "4.0.1"
        }
      ]
    },
    "valueSets": {
      "def": [
        {
          "name": "Pap Test",
          "id": "2.16.840.1.113883.3.464.1003.108.12.1017",
          "accessLevel": "Public"
        }
      ]
    },
    "statements": {
      "def": [
        {
          "name": "Patient",
          "context": "Patient",
          "expression": {
            "type": "SingletonFrom",
            "operand": {
              "dataType": "{http://hl7.org/fhir}Patient",
              "templateId": "http://hl7.org/fhir/StructureDefinition/Patient",
              "type": "Retrieve"
            }
          }
        },
        {
          "name": "In Demographic",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "And",
            "operand": [
              {
                "type": "GreaterOrEqual",
                "operand": [
                  {
                    "precision": "Year",
                    "type": "CalculateAge",
                    "operand": {
                      "path": "birthDate",
                      "type": "Property",
                      "source": {
                        "name": "Patient",
                        "type": "ExpressionRef"
                      }
                    }
                  },
                  {
                    "valueType": "{urn:hl7-org:elm-types:r1}Integer",
                    "value": "30",
                    "type": "Literal"
                  }
                ]
              },
              {
                "type": "LessOrEqual",
                "operand": [
                  {
                    "precision": "Year",
                    "type": "CalculateAge",
                    "operand": {
                      "path": "birthDate",
                      "type": "Property",
                      "source": {
                        "name": "Patient",
                        "type": "ExpressionRef"
                      }
                    }
                  },
                  {
                    "valueType": "{urn:hl7-org:elm-types:r1}Integer",
                    "value": "65",
                    "type": "Literal"
                  }
                ]
              }
            ]
          }
        },
        {
          "name": "Is Female",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Equal",
            "operand": [
              {
                "path": "gender.value",
                "type": "Property",
                "source": {
                  "name": "Patient",
                  "type": "ExpressionRef"
                }
              },
              {
                "valueType": "{urn:hl7-org:elm-types:r1}String",
                "value": "female",
                "type": "Literal"
              }
            ]
          }
        },
        {
          "name": "Has Recent Pap Smear",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Exists",
            "operand": {
              "type": "Query",
              "source": [
                {
                  "alias": "S",
                  "expression": {
                    "dataType": "{http://hl7.org/fhir}Observation",
                    "templateId": "http://hl7.org/fhir/StructureDefinition/Observation",
                    "codeProperty": "code",
                    "type": "Retrieve",
                    "codes": {
                      "name": "Pap Test",
                      "type": "ValueSetRef"
                    }
                  }
                }
              ],
              "relationship": [],
              "where": {
                "type": "In",
                "operand": [
                  {
                    "path": "issued",
                    "scope": "S",
                    "type": "Property"
                  },
                  {
                    "lowClosed": true,
                    "highClosed": true,
                    "type": "Interval",
                    "low": {
                      "type": "Subtract",
                      "operand": [
                        {
                          "type": "Today"
                        },
                        {
                          "value": 3,
                          "unit": "years",
                          "type": "Quantity"
                        }
                      ]
                    },
                    "high": {
                      "type": "Today"
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "name": "Needs Cervical Cancer Screening",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "And",
            "operand": [
              {
                "type": "And",
                "operand": [
                  {
                    "name": "In Demographic",
                    "type": "ExpressionRef"
                  },
                  {
                    "name": "Is Female",
                    "type": "ExpressionRef"
                  }
                ]
              },
              {
                "type": "Not",
                "operand": {
                  "name": "Has Recent Pap Smear",
                  "type": "ExpressionRef"
                }
              }
            ]
          }
        },
        {
          "name": "InPopulation",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "name": "Needs Cervical Cancer Screening",
            "type": "ExpressionRef"
          }
        },
        {
          "name": "Recommendation",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "InPopulation",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "Perform cervical cytology (Pap smear) for cervical cancer screening",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        },
        {
          "name": "Rationale",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "InPopulation",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "USPSTF recommends screening for cervical cancer every 3 years with cervical cytology alone in women aged 21-65 years.",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        },
        {
          "name": "Indicator",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "InPopulation",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "warning",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        }
      ]
    }
  }
}