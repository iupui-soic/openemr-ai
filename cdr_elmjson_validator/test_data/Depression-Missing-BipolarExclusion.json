            "name": "LOINC"
          }
        }
      ]
    },
    "valueSets": {
      "def": [
        {
          "name": "Bipolar Diagnosis",
          "id": "2.16.840.1.113883.3.600.450",
          "accessLevel": "Public"
        },
        {
          "name": "Depression Diagnosis",
          "id": "2.16.840.1.113883.3.600.145",
          "accessLevel": "Public"
        },
        {
          "name": "Encounter to Screen for Depression",
          "id": "2.16.840.1.113883.3.600.1916",
          "accessLevel": "Public"
        },
        {
          "name": "Adolescent Depression Screening",
          "id": "2.16.840.1.113883.3.600.559",
          "accessLevel": "Public"
        },
        {
          "name": "Adult Depression Screening",
          "id": "2.16.840.1.113883.3.600.564",
          "accessLevel": "Public"
        },
        {
          "name": "Follow Up for Adolescent Depression",
          "id": "2.16.840.1.113883.3.526.3.1569",
          "accessLevel": "Public"
        },
        {
          "name": "Follow Up for Adult Depression",
          "id": "2.16.840.1.113883.3.526.3.1568",
          "accessLevel": "Public"
        },
        {
          "name": "Adolescent Depression Medications",
          "id": "2.16.840.1.113883.3.526.3.1567",
          "accessLevel": "Public"
        },
        {
          "name": "Adult Depression Medications",
          "id": "2.16.840.1.113883.3.526.3.1566",
          "accessLevel": "Public"
        }
      ]
    },
    "statements": {
      "def": [
        {
          "name": "Patient",
          "context": "Patient",
          "expression": {
            "type": "SingletonFrom",
            "operand": {
              "dataType": "{http://hl7.org/fhir}Patient",
              "templateId": "http://hl7.org/fhir/StructureDefinition/Patient",
              "type": "Retrieve"
            }
          }
        },
        {
          "name": "In Demographic",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "GreaterOrEqual",
            "operand": [
              {
                "precision": "Year",
                "type": "CalculateAge",
                "operand": {
                  "path": "birthDate",
                  "type": "Property",
                  "source": {
                    "name": "Patient",
                    "type": "ExpressionRef"
                  }
                }
              },
              {
                "valueType": "{urn:hl7-org:elm-types:r1}Integer",
                "value": "12",
                "type": "Literal"
              }
            ]
          }
        },
        {
          "name": "Has Bipolar Diagnosis",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Exists",
            "operand": {
              "type": "Query",
              "source": [
                {
                  "alias": "B",
                  "expression": {
                    "dataType": "{http://hl7.org/fhir}Condition",
                    "templateId": "http://hl7.org/fhir/StructureDefinition/Condition",
                    "codeProperty": "code",
                    "type": "Retrieve",
                    "codes": {
                      "name": "Bipolar Diagnosis",
                      "type": "ValueSetRef"
                    }
                  }
                }
              ],
              "relationship": [],
              "where": {
                "type": "Equal",
                "operand": [
                  {
                    "path": "clinicalStatus.coding[0].code",
                    "scope": "B",
                    "type": "Property"
                  },
                  {
                    "valueType": "{urn:hl7-org:elm-types:r1}String",
                    "value": "active",
                    "type": "Literal"
                  }
                ]
              }
            }
          }
        },
        {
          "name": "Has Depression Diagnosis",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Exists",
            "operand": {
              "type": "Query",
              "source": [
                {
                  "alias": "D",
                  "expression": {
                    "dataType": "{http://hl7.org/fhir}Condition",
                    "templateId": "http://hl7.org/fhir/StructureDefinition/Condition",
                    "codeProperty": "code",
                    "type": "Retrieve",
                    "codes": {
                      "name": "Depression Diagnosis",
                      "type": "ValueSetRef"
                    }
                  }
                }
              ],
              "relationship": [],
              "where": {
                "type": "Equal",
                "operand": [
                  {
                    "path": "clinicalStatus.coding[0].code",
                    "scope": "D",
                    "type": "Property"
                  },
                  {
                    "valueType": "{urn:hl7-org:elm-types:r1}String",
                    "value": "active",
                    "type": "Literal"
                  }
                ]
              }
            }
          }
        },
        {
          "name": "Has Recent Adult Depression Screening",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Exists",
            "operand": {
              "type": "Query",
              "source": [
                {
                  "alias": "S",
                  "expression": {
                    "dataType": "{http://hl7.org/fhir}Observation",
                    "templateId": "http://hl7.org/fhir/StructureDefinition/Observation",
                    "codeProperty": "code",
                    "type": "Retrieve",
                    "codes": {
                      "name": "Adult Depression Screening",
                      "type": "ValueSetRef"
                    }
                  }
                }
              ],
              "relationship": [],
              "where": {
                "type": "And",
                "operand": [
                  {
                    "type": "In",
                    "operand": [
                      {
                        "path": "issued",
                        "scope": "S",
                        "type": "Property"
                      },
                      {
                        "lowClosed": true,
                        "highClosed": true,
                        "type": "Interval",
                        "low": {
                          "type": "Subtract",
                          "operand": [
                            {
                              "type": "Today"
                            },
                            {
                              "value": 1,
                              "unit": "years",
                              "type": "Quantity"
                            }
                          ]
                        },
                        "high": {
                          "type": "Today"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Not",
                    "operand": {
                      "type": "IsNull",
                      "operand": {
                        "path": "value",
                        "scope": "S",
                        "type": "Property"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "name": "Has Recent Adolescent Depression Screening",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Exists",
            "operand": {
              "type": "Query",
              "source": [
                {
                  "alias": "S",
                  "expression": {
                    "dataType": "{http://hl7.org/fhir}Observation",
                    "templateId": "http://hl7.org/fhir/StructureDefinition/Observation",
                    "codeProperty": "code",
                    "type": "Retrieve",
                    "codes": {
                      "name": "Adolescent Depression Screening",
                      "type": "ValueSetRef"
                    }
                  }
                }
              ],
              "relationship": [],
              "where": {
                "type": "And",
                "operand": [
                  {
                    "type": "In",
                    "operand": [
                      {
                        "path": "issued",
                        "scope": "S",
                        "type": "Property"
                      },
                      {
                        "lowClosed": true,
                        "highClosed": true,
                        "type": "Interval",
                        "low": {
                          "type": "Subtract",
                          "operand": [
                            {
                              "type": "Today"
                            },
                            {
                              "value": 1,
                              "unit": "years",
                              "type": "Quantity"
                            }
                          ]
                        },
                        "high": {
                          "type": "Today"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Not",
                    "operand": {
                      "type": "IsNull",
                      "operand": {
                        "path": "value",
                        "scope": "S",
                        "type": "Property"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "name": "Has Recent Screening",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "Or",
            "operand": [
              {
                "name": "Has Recent Adult Depression Screening",
                "type": "ExpressionRef"
              },
              {
                "name": "Has Recent Adolescent Depression Screening",
                "type": "ExpressionRef"
              }
            ]
          }
        },
        {
          "name": "Needs Depression Screening",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "And",
            "operand": [
              {
                "type": "And",
                "operand": [
                  {
                    "type": "And",
                    "operand": [
                      {
                        "name": "In Demographic",
                        "type": "ExpressionRef"
                      }
                    ]
                  },
                  {
                    "type": "Not",
                    "operand": {
                      "name": "Has Depression Diagnosis",
                      "type": "ExpressionRef"
                    }
                  }
                ]
              },
              {
                "type": "Not",
                "operand": {
                  "name": "Has Recent Screening",
                  "type": "ExpressionRef"
                }
              }
            ]
          }
        },
        {
          "name": "Recommendation",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "Needs Depression Screening",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "Perform depression screening using a standardized tool (e.g., PHQ-9 for adults, PHQ-A for adolescents)",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        },
        {
          "name": "Rationale",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "Needs Depression Screening",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "USPSTF recommends screening for depression in the general adult population (age 12+), including pregnant and postpartum persons. Screening should be implemented with adequate systems in place to ensure accurate diagnosis, effective treatment, and appropriate follow-up.",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        },
        {
          "name": "Indicator",
          "context": "Patient",
          "accessLevel": "Public",
          "expression": {
            "type": "If",
            "condition": {
              "name": "Needs Depression Screening",
              "type": "ExpressionRef"
            },
            "then": {
              "valueType": "{urn:hl7-org:elm-types:r1}String",
              "value": "warning",
              "type": "Literal"
            },
            "else": {
              "type": "Null"
            }
          }
        }
      ]
    }
  }
}